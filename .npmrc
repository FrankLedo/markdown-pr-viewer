# Supply-chain hardening: never auto-run package lifecycle scripts
# (preinstall/install/postinstall/prepare) on `npm install`. Lifecycle scripts
# are the primary npm malware vector. Post-install steps must be run explicitly:
#   - direct CLI commands work as-is:  `npx playwright install`,  `npx husky`
#   - native rebuilds must opt back in per-command:  `npm rebuild <pkg> --ignore-scripts=false`
#     (plain `npm rebuild` is itself suppressed by this setting)
ignore-scripts=true
